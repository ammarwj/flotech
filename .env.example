# ============================================================
# flo-event — root environment template (Docker Compose)
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# ---- General ----
COMPOSE_PROJECT_NAME=flo-event
APP_DOMAIN=flo-event.flotech.id
API_DOMAIN=api-flo-event.flotech.id
LETSENCRYPT_EMAIL=admin@flotech.id

# ---- PostgreSQL (db service) ----
POSTGRES_DB=flo_event
POSTGRES_USER=flo_user
POSTGRES_PASSWORD=change_me_strong_password

# ---- Redis (redis service) ----
REDIS_PASSWORD=change_me_redis_password

# ---- Laravel API (api/worker/scheduler services) ----
APP_NAME=flo-event
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api-flo-event.flotech.id
FRONTEND_URL=https://flo-event.flotech.id

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---- JWT (RS256) ----
JWT_ALGO=RS256
JWT_TTL=15
JWT_REFRESH_TTL=43200

# ---- Cloudflare R2 (S3-compatible) ----
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flo-event-storage
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.flo-event.id
R2_REGION=auto

# ---- Midtrans ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- Resend (email) ----
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@flo-event.id
MAIL_FROM_NAME=flo-event

# ---- Sentry ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ---- Frontend (web service) ----
NEXT_PUBLIC_API_URL=https://api-flo-event.flotech.id/api/v1
NEXT_PUBLIC_SENTRY_DSN=
