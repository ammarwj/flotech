APP_NAME=flo-event
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.flo-event.id
FRONTEND_URL=https://flo-event.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=flo_event
DB_USERNAME=flo_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- JWT (RS256 asymmetric) ----
JWT_ALGO=RS256
JWT_TTL=15
JWT_REFRESH_TTL=43200
JWT_PRIVATE_KEY=file://storage/jwt/jwt-private.pem
JWT_PUBLIC_KEY=file://storage/jwt/jwt-public.pem
JWT_PASSPHRASE=

# ---- Mail (Resend) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@flo-event.id"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# ---- Cloudflare R2 (S3-compatible) ----
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flo-event-storage
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.flo-event.id
R2_REGION=auto

# ---- Midtrans ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- Sentry ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

VITE_APP_NAME="${APP_NAME}"

# ---- Telescope (dev only) ----
TELESCOPE_ENABLED=false
